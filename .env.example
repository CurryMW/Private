# 必填：模型服务凭证。真实值只能保存在 .env 或 GitHub Secrets 中。
AI_API_KEY=
# 兼容 OpenAI Chat Completions 的接口地址和模型名称。
AI_BASE_URL=https://apiclaude.cc/v1
AI_MODEL=claude-sonnet-4-6

# 必填：钉钉机器人的 HTTPS Webhook，可以已经包含 access_token。
DINGTALK_WEBHOOK=
# 如果 DINGTALK_WEBHOOK 是包含 access_token 的完整 URL，此项可以留空。
DINGTALK_ACCESS_TOKEN=

WINDOW_HOURS=36
FALLBACK_WINDOW_HOURS=168
MAX_ITEMS=8
MODEL_CANDIDATE_LIMIT=12
MODEL_RETRY_CANDIDATE_LIMIT=6
TIMEZONE=Asia/Shanghai
# 安全的本地默认值：只预演，不发送钉钉消息，也不修改已发送状态。
DRY_RUN=true
STATE_PATH=.state/sent.json
# 本地可选；GitHub Actions 会自动提供只读 Job Token。
GITHUB_TOKEN=
